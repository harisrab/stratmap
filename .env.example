# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key are public (exposed to the browser via NEXT_PUBLIC_).
# Service role key is server-only — never prefix it with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket that holds the workspace tree (notes/, scenarios/, data/, layers/).
# Defaults to "stratmap-workspace" if unset.
SUPABASE_STORAGE_BUCKET=stratmap-workspace

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Public token used by the map canvas in the browser.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Optional server-side token. If unset, server code falls back to the public one.
MAPBOX_TOKEN=

# ─── Anthropic (chat agent) ──────────────────────────────────────────────────
# Required for /api/chat. Model defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-6
